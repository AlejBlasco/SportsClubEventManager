{
  "// INSTRUCTIONS": "This is a template for User Secrets configuration.",
  "// 1. Generate a secure JWT secret key (minimum 256 bits / 32 characters):",
  "//    - Use: openssl rand -base64 32",
  "//    - Or: PowerShell: [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Minimum 0 -Maximum 256 }))",
  "// 2. Register OAuth2 providers:",
  "//    - Google: https://console.cloud.google.com/apis/credentials",
  "//    - Microsoft: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps/ApplicationsListBlade",
  "// 3. Set User Secrets for API project:",
  "//    dotnet user-secrets init --project src/SportsClubEventManager.Api",
  "//    dotnet user-secrets set \"Authentication:JwtSettings:SecretKey\" \"YOUR_SECRET_KEY\" --project src/SportsClubEventManager.Api",
  "//    dotnet user-secrets set \"Authentication:Google:ClientId\" \"YOUR_GOOGLE_CLIENT_ID\" --project src/SportsClubEventManager.Api",
  "//    dotnet user-secrets set \"Authentication:Google:ClientSecret\" \"YOUR_GOOGLE_CLIENT_SECRET\" --project src/SportsClubEventManager.Api",
  "// 4. Set User Secrets for the Infrastructure project (used by the admin seed migration):",
  "//    dotnet user-secrets set \"AdminUser:Password\" \"YOUR_ADMIN_PASSWORD\" --project src/SportsClubEventManager.Infrastructure",

  "Authentication": {
    "JwtSettings": {
      "SecretKey": "REPLACE_WITH_GENERATED_SECRET_KEY_MINIMUM_32_CHARACTERS"
    },
    "Google": {
      "ClientId": "REPLACE_WITH_GOOGLE_CLIENT_ID",
      "ClientSecret": "REPLACE_WITH_GOOGLE_CLIENT_SECRET"
    }
  },
  "AdminUser": { "Password": "REPLACE_WITH_ADMIN_PASSWORD" }
}
