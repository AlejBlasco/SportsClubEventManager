# Copiar este fichero a .env y rellenar valores reales antes de `docker compose up`.
# Ver README.md, sección "c. Instalación y ejecución", para el detalle de cada variable.

# Contraseña SA de SQL Server — debe cumplir los requisitos de complejidad:
# mínimo 8 caracteres, mayúscula + minúscula + dígito + símbolo.
SA_PASSWORD=

# Cadena de conexión completa — mantener la contraseña sincronizada con SA_PASSWORD.
CONNECTION_STRING=Server=sqlserver,1433;Database=SportsClubEventManager;User Id=sa;Password=<igual-que-SA_PASSWORD>;TrustServerCertificate=True;MultipleActiveResultSets=true

# Puertos de host en los que se exponen los servicios.
API_PORT=5240
WEB_PORT=5123
SQL_PORT=1433

# Development habilita logging SQL detallado y Swagger UI; usar Production en despliegues reales.
ASPNETCORE_ENVIRONMENT=Development

# --- Obligatorias para que el contenedor api arranque (falla rápido en el arranque si faltan) ---
JWT_SECRET_KEY=
ADMIN_PASSWORD=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Opcional: URL pública de Web añadida a la lista de orígenes CORS de la Api ---
WEB_EXTERNAL_URL=
