# Copiar este fichero a .env y rellenar valores reales antes de `docker compose up`.
# Ver README.md, sección "c. Instalación y ejecución", para el detalle de cada variable.

# Contraseña SA de SQL Server — debe cumplir los requisitos de complejidad:
# mínimo 8 caracteres, mayúscula + minúscula + dígito + símbolo.
SA_PASSWORD=

# Cadena de conexión completa — mantener la contraseña sincronizada con SA_PASSWORD.
CONNECTION_STRING=Server=sqlserver,1433;Database=SportsClubEventManager;User Id=sa;Password=<igual-que-SA_PASSWORD>;TrustServerCertificate=True;MultipleActiveResultSets=true

# Puertos de host en los que se exponen los servicios.
API_PORT=5240
WEB_PORT=5123
SQL_PORT=1433

# Puerto de host en el que se expone la UI de Prometheus (issue #42). SOLO DESARROLLO LOCAL: en
# producción no se despliega ningún Prometheus propio de este proyecto — el homelab ya tiene el
# suyo en su stack `monitoring` preexistente; `api`/`web` se dan de alta ahí como scrape targets
# mediante un runbook manual (ver .claude/docs/sdlc/design/issue-42-integracion-prometheus-metricas.md,
# Apéndice A), no mediante este contenedor.
PROMETHEUS_PORT=9090

# Interfaz de red en la que se publica el puerto del Prometheus de desarrollo. Por defecto
# 127.0.0.1 (solo accesible desde la propia máquina) — no hay ningún valor de producción que fijar
# para esta variable, ver nota anterior.
PROMETHEUS_BIND_ADDRESS=127.0.0.1

# --- Grafana (issue #43) — SOLO DESARROLLO LOCAL, mismo caso que Prometheus arriba. En producción
# se usa el Grafana ya existente del stack `monitoring` del homelab, no un contenedor de este
# proyecto — ver el runbook "Apéndice A" del diseño de la issue #43
# (.claude/docs/sdlc/design/issue-43-dashboard-grafana-monitorizacion.md) para cómo se aplica y se
# publica de forma acotada (Grafana Public Dashboards + una ruta dedicada de Cloudflare Tunnel)
# el dashboard de este proyecto sobre esa Grafana compartida. ---
GRAFANA_PORT=3000
GRAFANA_BIND_ADDRESS=127.0.0.1
GRAFANA_ADMIN_PASSWORD=

# Development habilita logging SQL detallado y Swagger UI; usar Production en despliegues reales.
ASPNETCORE_ENVIRONMENT=Development

# --- Obligatorias para que el contenedor api arranque (falla rápido en el arranque si faltan) ---
JWT_SECRET_KEY=
ADMIN_PASSWORD=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Opcional: URL pública de Web añadida a la lista de orígenes CORS de la Api ---
WEB_EXTERNAL_URL=
