@using Radzen.Blazor

<div class="not-found-container">
    <div class="not-found-icon">🔍</div>
    <h2>Event Not Found</h2>
    <p class="not-found-message">The event you are looking for does not exist or has been removed.</p>
    <RadzenButton Text="Back to Events" Click="@NavigateToEvents"
                  ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Medium" />
</div>

@code {
    /// <summary>
    /// Gets or sets the navigation manager for routing.
    /// </summary>
    [Inject]
    private NavigationManager NavigationManager { get; set; } = default!;

    /// <summary>
    /// Navigates back to the events listing page.
    /// </summary>
    private void NavigateToEvents()
    {
        NavigationManager.NavigateTo("/events");
    }
}
