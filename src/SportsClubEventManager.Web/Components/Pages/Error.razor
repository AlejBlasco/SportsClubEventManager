@page "/Error"
@using System.Diagnostics

<PageTitle>500 &mdash; Server Error</PageTitle>

<div class="error-page">
    <div class="page-header">
        <div class="page-header-inner">
            <span class="page-eyebrow">Error 500</span>
            <h1>Something Went Wrong</h1>
            <p class="page-subtitle">An unexpected error occurred while processing your request.</p>
        </div>
    </div>

    <div class="error-content">
        <div class="error-inner">
            <div class="error-icon" aria-hidden="true">
                <svg width="72" height="72" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                    <path d="M12 9v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                    <circle cx="12" cy="17" r="0.6" fill="currentColor" stroke="currentColor" stroke-width="0.6" />
                </svg>
            </div>

            <p class="error-message">
                We are sorry for the inconvenience. Our team has been notified and is working on a fix.
                Please try again in a few moments.
            </p>

            @if (ShowRequestId)
            {
                <div class="error-request-id">
                    <span class="error-request-label">Request ID</span>
                    <code>@RequestId</code>
                </div>
            }

            <div class="error-actions">
                <a class="btn-primary-page" href="/">Back to Home</a>
                <a class="btn-secondary-page" href="/contact">Contact Support</a>
            </div>
        </div>
    </div>
</div>

@code {
    /// <summary>
    /// Gets or sets the HTTP context used to retrieve the request identifier.
    /// </summary>
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
