@page "/"

<PageTitle>Index</PageTitle>

<div class="index-page">
    <section class="hero-panel">
        <p class="hero-eyebrow">Sports Club Event Manager</p>
        <h1>Train, Compete, and Connect</h1>
        <p class="hero-copy">
            Discover upcoming sessions, reserve your place, and follow every event from one place,
            with a style inspired by classic sports club aesthetics.
        </p>
        <div class="hero-actions">
            <a class="btn btn-primary" href="/events">View Events</a>
            <a class="btn btn-outline" href="/events">Open Calendar</a>
        </div>
    </section>

    <section class="highlights-grid">
        <article class="highlight-card">
            <h2>Event Calendar</h2>
            <p>Explore monthly and yearly planning with a clean visual timeline.</p>
        </article>
        <article class="highlight-card">
            <h2>Fast Registration</h2>
            <p>Sign up or cancel registrations in seconds with real-time capacity updates.</p>
        </article>
        <article class="highlight-card">
            <h2>Club Atmosphere</h2>
            <p>A warm green and sand identity reflecting traditional sports facilities.</p>
        </article>
    </section>
</div>
