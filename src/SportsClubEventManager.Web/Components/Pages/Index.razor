@page "/"
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]

<PageTitle>Sports Club Event Manager</PageTitle>

<div class="home-page">

    <section class="hero-section">
        <div class="hero-inner">
            <div class="hero-text">
                <span class="hero-eyebrow">Sports Club Event Manager</span>
                <h1 class="hero-title">Train.<br />Compete.<br />Connect.</h1>
                <p class="hero-subtitle">
                    Discover upcoming sessions, reserve your spot, and follow every club event &mdash; all from one place.
                </p>
                <div class="hero-actions">
                    <a class="btn-hero-primary" href="/events">Browse Events</a>
                    <a class="btn-hero-secondary" href="/about">Learn More</a>
                </div>
            </div>
            <div class="hero-rings" aria-hidden="true">
                <div class="ring ring-a"></div>
                <div class="ring ring-b"></div>
                <div class="ring ring-c"></div>
                <div class="ring ring-d"></div>
                <div class="ring ring-e"></div>
            </div>
        </div>
    </section>

    <section class="stats-section">
        <div class="stats-inner">
            <div class="stat-item">
                <span class="stat-value">100%</span>
                <span class="stat-label">Club Focus</span>
            </div>
            <div class="stat-divider" aria-hidden="true"></div>
            <div class="stat-item">
                <span class="stat-value">Live</span>
                <span class="stat-label">Capacity Tracking</span>
            </div>
            <div class="stat-divider" aria-hidden="true"></div>
            <div class="stat-item">
                <span class="stat-value">Instant</span>
                <span class="stat-label">Registration</span>
            </div>
        </div>
    </section>

    <section class="features-section">
        <div class="features-inner">
            <h2 class="section-heading">Everything You Need</h2>
            <div class="features-grid">
                <article class="feature-card">
                    <div class="feature-icon-wrap">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <rect x="3" y="4" width="18" height="18" rx="2" stroke="currentColor" stroke-width="2" />
                            <path d="M16 2v4M8 2v4M3 10h18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                            <path d="M8 14h.01M12 14h.01M16 14h.01M8 18h.01M12 18h.01M16 18h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                        </svg>
                    </div>
                    <h3>Event Calendar</h3>
                    <p>Explore monthly and yearly planning with a clean visual timeline of all upcoming club events.</p>
                    <a class="feature-link" href="/events">View Calendar &rarr;</a>
                </article>

                <article class="feature-card feature-card--accent">
                    <div class="feature-icon-wrap">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </div>
                    <h3>Fast Registration</h3>
                    <p>Sign up or cancel registrations in seconds with real-time capacity updates and instant confirmation.</p>
                    <a class="feature-link" href="/events">Browse Events &rarr;</a>
                </article>

                <article class="feature-card">
                    <div class="feature-icon-wrap">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="2" />
                            <path d="M3 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                            <path d="M16 3.13a4 4 0 0 1 0 7.75M21 21v-2a4 4 0 0 0-3-3.87" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                        </svg>
                    </div>
                    <h3>Member Directory</h3>
                    <p>Connect with fellow club members and keep track of event participation across the season.</p>
                    <AuthorizeView Roles="Administrator">
                        <Authorized>
                            <a class="feature-link" href="/admin/users">View Members &rarr;</a>
                        </Authorized>
                    </AuthorizeView>
                </article>
            </div>
        </div>
    </section>

    <section class="cta-section">
        <div class="cta-inner">
            <h2>Ready to Join the Action?</h2>
            <p>Browse the latest events, pick your session, and register in under a minute.</p>
            <a class="btn-cta" href="/events">See All Events</a>
        </div>
    </section>

</div>
