@page "/my-registrations"
@using Microsoft.AspNetCore.Authorization
@using SportsClubEventManager.Domain.Enums
@using SportsClubEventManager.Shared.DTOs
@using SportsClubEventManager.Web.Services
@inject IRegistrationService RegistrationService
@attribute [Authorize]

<PageTitle>My Registrations - Sports Club Event Manager</PageTitle>

<div class="admin-page">
    <div class="page-header">
        <h1>
            <i class="bi bi-person-check"></i>
            My Registrations
        </h1>
        <p class="page-description">
            View and manage your active registrations.
        </p>
    </div>

    @if (_errorMessage is not null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle"></i> @_errorMessage
            <button type="button" class="btn-close" @onclick="(() => _errorMessage = null)"></button>
        </div>
    }

    @if (_successMessage is not null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle"></i> @_successMessage
            <button type="button" class="btn-close" @onclick="(() => _successMessage = null)"></button>
        </div>
    }

    @if (_loading)
    {
        <div class="text-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-2">Loading your registrations...</p>
        </div>
    }
    else if (_registrations.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Event</th>
                        <th>Date</th>
                        <th>Location</th>
                        <th>Registered On</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var registration in _registrations)
                    {
                        <tr>
                            <td>@registration.EventTitle</td>
                            <td>@registration.EventDate.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@registration.EventLocation</td>
                            <td>@registration.RegistrationDate.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                <span class="badge @(registration.Status == RegistrationStatus.Registered ? "bg-success" : "bg-secondary")">
                                    @registration.Status
                                </span>
                            </td>
                            <td>
                                <button class="btn btn-sm btn-outline-danger"
                                        disabled="@(!registration.CanBeCancelledByUser || _processingRegistrationId == registration.RegistrationId)"
                                        @onclick="() => CancelAsync(registration)">
                                    @if (_processingRegistrationId == registration.RegistrationId)
                                    {
                                        <span>Cancelling...</span>
                                    }
                                    else
                                    {
                                        <span>Cancel</span>
                                    }
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center">
            <i class="bi bi-info-circle"></i> You do not have active registrations.
        </div>
    }
</div>
