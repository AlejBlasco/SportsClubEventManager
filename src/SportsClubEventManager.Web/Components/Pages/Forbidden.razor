@page "/forbidden"
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@using Microsoft.AspNetCore.Components.Authorization

<PageTitle>Access Denied - Sports Club Event Manager</PageTitle>

<div class="forbidden-container">
    <div class="forbidden-content">
        <div class="forbidden-icon">
            <i class="bi bi-shield-x"></i>
        </div>
        <h1>Access Denied</h1>
        <p class="forbidden-message">
            You do not have permission to access this resource.
        </p>
        <AuthorizeView>
            <Authorized>
                <p class="forbidden-details">
                    If you believe you should have access to this page, please contact your system administrator.
                </p>
            </Authorized>
            <NotAuthorized>
                <p class="forbidden-details">
                    You need to be logged in to access this page.
                </p>
            </NotAuthorized>
        </AuthorizeView>
        <div class="forbidden-actions">
            <a href="/" class="btn btn-primary">
                <i class="bi bi-house-door"></i> Return to Home
            </a>
            <AuthorizeView>
                <NotAuthorized>
                    <a href="/login" class="btn btn-secondary">
                        <i class="bi bi-box-arrow-in-right"></i> Sign In
                    </a>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </div>
</div>

<style>
    .forbidden-container {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 60vh;
        padding: 2rem;
    }

    .forbidden-content {
        text-align: center;
        max-width: 600px;
    }

    .forbidden-icon {
        font-size: 6rem;
        color: var(--rz-danger, #dc3545);
        margin-bottom: 1.5rem;
    }

    .forbidden-content h1 {
        font-size: 2.5rem;
        font-weight: 600;
        margin-bottom: 1rem;
        color: var(--rz-text-color, #333);
    }

    .forbidden-message {
        font-size: 1.25rem;
        color: var(--rz-text-secondary-color, #666);
        margin-bottom: 1rem;
    }

    .forbidden-details {
        font-size: 1rem;
        color: var(--rz-text-secondary-color, #666);
        margin-bottom: 2rem;
    }

    .forbidden-actions {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    .forbidden-actions .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.5rem;
        font-size: 1rem;
        text-decoration: none;
        border-radius: 0.375rem;
        transition: all 0.2s ease;
    }

    .btn-primary {
        background-color: var(--rz-primary, #007bff);
        color: white;
        border: 1px solid var(--rz-primary, #007bff);
    }

    .btn-primary:hover {
        background-color: var(--rz-primary-dark, #0056b3);
    }

    .btn-secondary {
        background-color: var(--rz-secondary, #6c757d);
        color: white;
        border: 1px solid var(--rz-secondary, #6c757d);
    }

    .btn-secondary:hover {
        background-color: var(--rz-secondary-dark, #5a6268);
    }
</style>
