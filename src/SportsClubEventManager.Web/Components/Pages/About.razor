@page "/about"
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]

<PageTitle>About &mdash; Sports Club</PageTitle>

<div class="about-page">

    <div class="page-header">
        <div class="page-header-inner">
            <span class="page-eyebrow">Our Story</span>
            <h1>About the Club</h1>
            <p class="page-subtitle">Built to bring athletes and enthusiasts together around great events.</p>
        </div>
    </div>

    <div class="about-content">
        <div class="about-inner">

            <section class="about-section about-section--lead">
                <p class="lead-text">
                    Sports Club Event Manager is a platform designed to help sports clubs organise, promote
                    and manage their events &mdash; from weekly training sessions to full competitions.
                </p>
            </section>

            <section class="about-section">
                <div class="about-grid">
                    <div class="about-text-block">
                        <h2>What We Do</h2>
                        <p>
                            We give club organisers a simple, reliable tool to publish upcoming events and
                            manage attendance capacity in real time. Members can browse the calendar, register
                            for sessions in seconds, and cancel if their plans change &mdash; with no friction.
                        </p>
                        <p>
                            Every registration is confirmed immediately, and the capacity indicator updates
                            live so you always know whether a slot is still available before you commit.
                        </p>
                    </div>
                    <div class="about-values">
                        <div class="value-card">
                            <div class="value-icon" aria-hidden="true">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                                </svg>
                            </div>
                            <h3>Excellence</h3>
                            <p>Clean, fast, and reliable event management for every club size.</p>
                        </div>
                        <div class="value-card">
                            <div class="value-icon" aria-hidden="true">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                                    <circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="2" />
                                    <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                                </svg>
                            </div>
                            <h3>Community</h3>
                            <p>Connecting members, organisers and volunteers around shared events.</p>
                        </div>
                        <div class="value-card">
                            <div class="value-icon" aria-hidden="true">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                                </svg>
                            </div>
                            <h3>Speed</h3>
                            <p>Register or cancel in seconds. Capacity updates happen in real time.</p>
                        </div>
                    </div>
                </div>
            </section>

            <section class="about-section">
                <h2>Technology</h2>
                <p>
                    The platform is built on <strong>.NET 8</strong> with <strong>Blazor</strong> for the
                    frontend and a <strong>RESTful API</strong> backend following Clean Architecture principles.
                    Data is persisted in a relational database managed by Entity Framework Core,
                    while the UI is styled with a custom design system inspired by classic sports aesthetics.
                </p>
            </section>

            <section class="about-section about-section--cta">
                <h2>Get Started</h2>
                <p>Browse the current event calendar and reserve your place today.</p>
                <div class="about-actions">
                    <a class="btn-primary-about" href="/events">Browse Events</a>
                    <AuthorizeView Roles="Administrator">
                        <Authorized>
                            <a class="btn-secondary-about" href="/admin/users">View Members</a>
                        </Authorized>
                    </AuthorizeView>
                </div>
            </section>

        </div>
    </div>

</div>
