@page "/404"

<PageTitle>404 &mdash; Page Not Found</PageTitle>

<div class="notfound-page">
    <div class="page-header">
        <div class="page-header-inner">
            <span class="page-eyebrow">Error 404</span>
            <h1>Page Not Found</h1>
            <p class="page-subtitle">The page you are looking for does not exist or has been moved.</p>
        </div>
    </div>

    <div class="notfound-content">
        <div class="notfound-inner">
            <div class="notfound-icon" aria-hidden="true">
                <svg width="72" height="72" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="11" cy="11" r="7.5" stroke="currentColor" stroke-width="1.5" />
                    <path d="M21 21l-4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                    <path d="M8.5 11h5M11 8.5v5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                </svg>
            </div>
            <p class="notfound-message">
                We could not find what you were looking for. The page may have been removed, renamed, or is temporarily unavailable.
            </p>
            <div class="notfound-actions">
                <a class="btn-primary-page" href="/">Back to Home</a>
                <a class="btn-secondary-page" href="/events">Browse Events</a>
            </div>
            <div class="notfound-links">
                <p class="notfound-links-label">Quick links</p>
                <ul>
                    <li><a href="/events">Events Calendar</a></li>
                    <li><a href="/about">About the Club</a></li>
                    <li><a href="/contact">Contact Us</a></li>
                    <li><a href="/faq">Frequently Asked Questions</a></li>
                </ul>
            </div>
        </div>
    </div>
</div>
