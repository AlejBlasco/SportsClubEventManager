@page "/admin/registrations"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using SportsClubEventManager.Domain.Enums
@using SportsClubEventManager.Shared.DTOs
@using SportsClubEventManager.Web.Services
@inject IAdminRegistrationManagementService AdminRegistrationManagementService
@inject IUserManagementService UserManagementService
@inject IEventManagementService EventManagementService
@inject IJSRuntime JSRuntime
@attribute [Authorize(Roles = "Administrator")]

<PageTitle>Registration Management - Sports Club Event Manager</PageTitle>

<div class="admin-page">
    <div class="page-header">
        <div class="page-header-inner">
            <h1>
                <i class="bi bi-clipboard-check"></i>
                Registration Management
            </h1>
            <p class="page-subtitle">
                Manage registrations globally, apply filters, and perform manual registrations.
            </p>
            <div class="page-header-actions">
                <div class="export-dropdown">
                    <button class="btn btn-outline-light dropdown-toggle" type="button">
                        <i class="bi bi-download"></i> Export
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li>
                            <button class="dropdown-item" type="button" @onclick="ExportCsvAsync">
                                <i class="bi bi-filetype-csv"></i> CSV
                            </button>
                        </li>
                        <li>
                            <button class="dropdown-item" type="button" @onclick="ExportPdfAsync">
                                <i class="bi bi-file-earmark-pdf"></i> PDF
                            </button>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    @if (_errorMessage is not null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle"></i> @_errorMessage
            <button type="button" class="btn-close" @onclick="(() => _errorMessage = null)"></button>
        </div>
    }

    @if (_successMessage is not null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle"></i> @_successMessage
            <button type="button" class="btn-close" @onclick="(() => _successMessage = null)"></button>
        </div>
    }

    <div class="filters-section">
        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Search</label>
                <input type="text" class="form-control" placeholder="Event title, user name or email..." @bind="_searchText" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Status</label>
                <select class="form-select" @bind="_statusFilter">
                    <option value="">All</option>
                    <option value="Registered">Registered</option>
                    <option value="Cancelled">Cancelled</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Event From</label>
                <input type="date" class="form-control" @bind="_eventDateFrom" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Event To</label>
                <input type="date" class="form-control" @bind="_eventDateTo" />
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button class="btn btn-primary w-100" @onclick="ApplyFiltersAsync">
                    <i class="bi bi-funnel"></i> Apply
                </button>
            </div>
        </div>

        <div class="row g-3 mt-2">
            <div class="col-md-2">
                <label class="form-label">Sort By</label>
                <select class="form-select" @bind="_sortBy">
                    <option value="RegistrationDate">Registration Date</option>
                    <option value="EventDate">Event Date</option>
                    <option value="EventTitle">Event</option>
                    <option value="UserName">User</option>
                    <option value="Status">Status</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Order</label>
                <select class="form-select" @bind="_sortOrder">
                    <option value="desc">Descending</option>
                    <option value="asc">Ascending</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Manual Registration - User</label>
                <select class="form-select" @bind="_manualUserId">
                    <option value="">Select a user...</option>
                    @foreach (var user in _activeUsers)
                    {
                        <option value="@user.Id">@user.Name (@user.Email)</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Manual Registration - Event</label>
                <select class="form-select" @bind="_manualEventId">
                    <option value="">Select an event...</option>
                    @foreach (var evt in _upcomingEvents)
                    {
                        <option value="@evt.Id">@evt.Title (@evt.Date.ToString("yyyy-MM-dd HH:mm"))</option>
                    }
                </select>
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button class="btn btn-success w-100" @onclick="CreateManualRegistrationAsync" disabled="@_creatingRegistration">
                    @if (_creatingRegistration)
                    {
                        <span>Creating...</span>
                    }
                    else
                    {
                        <span>Create</span>
                    }
                </button>
            </div>
        </div>
    </div>

    @if (_loading)
    {
        <div class="text-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-2">Loading registrations...</p>
        </div>
    }
    else if (_registrations is not null && _registrations.Items.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Event</th>
                        <th>Event Date</th>
                        <th>User</th>
                        <th>Email</th>
                        <th>Registered On</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var registration in _registrations.Items)
                    {
                        <tr>
                            <td>@registration.EventTitle</td>
                            <td>@registration.EventDate.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@registration.UserName</td>
                            <td>@registration.UserEmail</td>
                            <td>@registration.RegistrationDate.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                <span class="badge @(registration.Status == RegistrationStatus.Registered ? "bg-success" : "bg-secondary")">
                                    @registration.Status
                                </span>
                            </td>
                            <td>
                                <div class="table-actions">
                                    <button class="btn btn-sm btn-outline-danger"
                                            @onclick="() => ConfirmCancelAsync(registration.RegistrationId)"
                                            disabled="@(registration.Status != RegistrationStatus.Registered)">
                                        <i class="bi bi-x-circle"></i> Cancel
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <nav aria-label="Registration list pagination">
            <ul class="pagination justify-content-center">
                <li class="page-item @(!_registrations.HasPreviousPage ? "disabled" : "")">
                    <button class="page-link" @onclick="(() => ChangePageAsync(_registrations.PageNumber - 1))" disabled="@(!_registrations.HasPreviousPage)">
                        Previous
                    </button>
                </li>
                @for (var i = 1; i <= _registrations.TotalPages; i++)
                {
                    var pageNumber = i;
                    <li class="page-item @(pageNumber == _registrations.PageNumber ? "active" : "")">
                        <button class="page-link" @onclick="(() => ChangePageAsync(pageNumber))">@pageNumber</button>
                    </li>
                }
                <li class="page-item @(!_registrations.HasNextPage ? "disabled" : "")">
                    <button class="page-link" @onclick="(() => ChangePageAsync(_registrations.PageNumber + 1))" disabled="@(!_registrations.HasNextPage)">
                        Next
                    </button>
                </li>
            </ul>
        </nav>

        <p class="text-center text-muted">
            Showing @(_registrations.Items.Count()) of @_registrations.TotalCount registrations
        </p>
    }
    else
    {
        <div class="alert alert-info text-center">
            <i class="bi bi-info-circle"></i> No registrations found matching your filters.
        </div>
    }
</div>
