@page "/admin/users"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Administrator")]

<PageTitle>User Management - Sports Club Event Manager</PageTitle>

<div class="admin-page">
    <div class="page-header">
        <h1>
            <i class="bi bi-people"></i>
            User Management
        </h1>
        <p class="page-description">
            Manage user accounts and roles
        </p>
    </div>

    <div class="content-placeholder">
        <div class="placeholder-icon">
            <i class="bi bi-tools"></i>
        </div>
        <h2>Coming Soon</h2>
        <p>
            User management functionality is currently under development.
            This page will allow you to:
        </p>
        <ul class="feature-list">
            <li><i class="bi bi-check-circle"></i> View all registered users</li>
            <li><i class="bi bi-check-circle"></i> Assign and modify user roles</li>
            <li><i class="bi bi-check-circle"></i> Activate and deactivate user accounts</li>
            <li><i class="bi bi-check-circle"></i> View user activity logs</li>
        </ul>
        <div class="placeholder-actions">
            <a href="/" class="btn btn-primary">
                <i class="bi bi-house-door"></i> Return to Home
            </a>
        </div>
    </div>
</div>

<style>
    .admin-page {
        padding: 2rem;
        max-width: 1200px;
        margin: 0 auto;
    }

    .page-header {
        margin-bottom: 2rem;
    }

    .page-header h1 {
        font-size: 2rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        color: var(--rz-text-color, #333);
    }

    .page-header h1 i {
        color: var(--rz-primary, #007bff);
    }

    .page-description {
        font-size: 1rem;
        color: var(--rz-text-secondary-color, #666);
        margin: 0;
    }

    .content-placeholder {
        background: var(--rz-panel-background, #fff);
        border: 1px solid var(--rz-panel-border-color, #dee2e6);
        border-radius: 0.5rem;
        padding: 3rem;
        text-align: center;
    }

    .placeholder-icon {
        font-size: 4rem;
        color: var(--rz-secondary, #6c757d);
        margin-bottom: 1.5rem;
    }

    .content-placeholder h2 {
        font-size: 1.75rem;
        font-weight: 600;
        margin-bottom: 1rem;
        color: var(--rz-text-color, #333);
    }

    .content-placeholder p {
        font-size: 1.125rem;
        color: var(--rz-text-secondary-color, #666);
        margin-bottom: 1.5rem;
    }

    .feature-list {
        list-style: none;
        padding: 0;
        margin: 2rem auto;
        max-width: 500px;
        text-align: left;
    }

    .feature-list li {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem;
        font-size: 1rem;
        color: var(--rz-text-color, #333);
    }

    .feature-list li i {
        color: var(--rz-success, #28a745);
        font-size: 1.25rem;
    }

    .placeholder-actions {
        margin-top: 2rem;
    }

    .placeholder-actions .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.5rem;
        font-size: 1rem;
        text-decoration: none;
        border-radius: 0.375rem;
        transition: all 0.2s ease;
    }

    .btn-primary {
        background-color: var(--rz-primary, #007bff);
        color: white;
        border: 1px solid var(--rz-primary, #007bff);
    }

    .btn-primary:hover {
        background-color: var(--rz-primary-dark, #0056b3);
    }
</style>
