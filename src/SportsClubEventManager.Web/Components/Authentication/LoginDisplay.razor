@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation
@inject IConfiguration Configuration
@inject HttpClient HttpClient

<AuthorizeView>
    <Authorized>
        <div class="user-info">
            <span class="user-name">Hello, @context.User.Identity?.Name</span>
            <button class="btn btn-sm btn-outline-secondary" @onclick="HandleLogout">
                Logout
            </button>
        </div>
    </Authorized>
    <NotAuthorized>
        <a href="/login" class="btn btn-sm btn-primary">Login</a>
    </NotAuthorized>
</AuthorizeView>

<style>
    .user-info {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .user-name {
        color: #333;
        font-weight: 500;
    }
</style>

@code {
    private async Task HandleLogout()
    {
        try
        {
            var apiBaseUrl = Configuration["ApiSettings:BaseUrl"] ?? "https://localhost:5001";
            await HttpClient.PostAsync($"{apiBaseUrl}/api/authentication/logout", null);

            Navigation.NavigateTo("/login", forceLoad: true);
        }
        catch
        {
            Navigation.NavigateTo("/login", forceLoad: true);
        }
    }
}
