@inherits LayoutComponentBase

<div class="page-wrapper">
    <header class="site-header">
        <NavMenu />
    </header>

    <main class="site-main">
        @Body
    </main>

    <footer class="site-footer">
        <div class="footer-inner">
            <div class="footer-brand-col">
                <span class="footer-brand">Sports Club Event Manager</span>
                <span class="footer-tagline">Train. Compete. Connect.</span>
            </div>
            <nav class="footer-nav" aria-label="Footer navigation">
                <div class="footer-nav-group">
                    <span class="footer-nav-heading">Club</span>
                    <a class="footer-link" href="/events">Events</a>
                    <a class="footer-link" href="/about">About</a>
                    <a class="footer-link" href="/contact">Contact</a>
                    <a class="footer-link" href="/faq">FAQ</a>
                </div>
                <div class="footer-nav-group">
                    <span class="footer-nav-heading">Legal</span>
                    <a class="footer-link" href="/privacy-policy">Privacy Policy</a>
                    <a class="footer-link" href="/terms-and-conditions">Terms &amp; Conditions</a>
                    <a class="footer-link" href="/cookie-policy">Cookie Policy</a>
                </div>
            </nav>
        </div>
        <div class="footer-bottom">
            <div class="footer-bottom-inner">
                <span class="footer-copy">&copy; @DateTime.Now.Year Sports Club Event Manager &mdash; All rights reserved.</span>
            </div>
        </div>
    </footer>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
