@using SportsClubEventManager.Web.Components.Authentication
@implements IDisposable
@inject NavigationManager Navigation

@code {
    private bool _isAdminSectionActive;

    protected override void OnInitialized()
    {
        _isAdminSectionActive = IsAdminPath(Navigation.Uri);
        Navigation.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _isAdminSectionActive = IsAdminPath(e.Location);
        InvokeAsync(StateHasChanged);
    }

    private bool IsAdminPath(string uri)
    {
        var relativePath = Navigation.ToBaseRelativePath(uri);
        return relativePath.StartsWith("admin/", StringComparison.OrdinalIgnoreCase);
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
